module tsc(
input clk,
input rst,
output reg STOP,READY,GO);
reg [1:0]state;
reg [7:0]counter;

localparam RED = 2'd0;
localparam YELLOW = 2'd1;
localparam GREEN = 2'd2;

localparam red_time = 8'd5;
localparam yellow_time = 8'd3;
localparam green_time = 8'd7;

always @(posedge clk or posedge rst)
begin
if(rst)begin
STOP <= 0;
READY <= 0;
GO <= 0;
state <= RED;
counter <= 0;
end
else begin
case (state)
    RED : begin
          STOP <= 1;
          READY <= 0;
          GO <= 0;
          if(counter == red_time)begin
              counter <= 0;
              state <= YELLOW;
          end
          else 
             counter <= counter +1;
          end
 YELLOW : begin
          STOP <= 0;
          READY <= 1;
          GO <= 0;
          if(counter == yellow_time)begin
              state <= GREEN;
              counter <= 0;
          end
          else 
              counter <= counter +1;
            
          end
 GREEN  : begin
          STOP <= 0;
          READY <= 0;
          GO <= 1;
         if(counter == green_time)begin
             state <= RED;
             counter <= 0;
         end
         else 
              counter <= counter +1;
       
          
          end
endcase
end
end
endmodule
